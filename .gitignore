# ========== 项目专用忽略 ==========
# 日志目录（包含 app.log 等运行日志）
/logs/

# VSCode 本地配置
/.vscode/

# 本地开发文件
.dev

# ========== Go 通用忽略 ==========
# 编译产物（可执行文件/动态库/中间文件）
*.exe
*.exe~
*.dll
*.so
*.dylib
*.o
*.a
*.out

# Go 工作区与构建目录
/go.work
/go.work.sum
/pkg/
/bin/
/obj/

# 临时文件
*.tmp
*.temp

# 系统文件
.DS_Store
Thumbs.db

# 测试覆盖率文件
coverage.txt

# 如使用 vendor 且不想提交可打开以下忽略
# /vendor/

# ========== 可选忽略（按需保留） ==========
# 本地敏感配置文件（生产密钥等）
/configs/config.yaml

# Swagger 静态产物（若采用动态生成可打开）
# /docs/swagger.json
# /docs/swagger.yaml
